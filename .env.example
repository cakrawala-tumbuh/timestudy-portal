# Required — backend URL for server-side requests (SSR / API routes)
BACKEND_URL=http://localhost:8000

# Required — exposed to the browser (build-time variable)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Required — NextAuth signing secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=change_me_in_production

# Required — canonical URL of the Next.js app
NEXTAUTH_URL=http://localhost:3000

# Optional — path ke file branding.json (default: <cwd>/data/branding.json)
# Untuk Docker: mount volume ke direktori ini agar data persisten antar restart
# BRANDING_FILE_PATH=/app/data/branding.json
